{
	"name": "@d-zero/remote-inspector",
	"version": "0.4.0",
	"description": "Compare local and remote files via SSH/SFTP before deployment",
	"author": "D-ZERO",
	"license": "MIT",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"bin": "dist/cli.js",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc",
		"watch": "tsc --watch",
		"clean": "rm -rf dist"
	},
	"dependencies": {
		"@d-zero/cli-core": "1.1.0",
		"ansi-colors": "^4.1.3",
		"diff": "^7.0.0",
		"dotenv": "^16.4.5",
		"ssh2-sftp-client": "^12.0.0"
	},
	"devDependencies": {
		"@types/diff": "6.0.0",
		"@types/ssh2-sftp-client": "9.0.4",
		"typescript": "5.8.3"
	},
	"publishConfig": {
		"access": "public"
	}
}
