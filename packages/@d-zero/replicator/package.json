		"watch": "tsc --watch",
		"clean": "tsc --build --clean"
	},
	"dependencies": {
		"@d-zero/cli-core": "1.3.8",
		"@d-zero/dealer": "1.7.4",
		"@d-zero/puppeteer-dealer": "0.7.10",
		"@d-zero/puppeteer-page-scan": "4.4.10",
		"@d-zero/puppeteer-scroll": "3.1.18",
		"@d-zero/shared": "0.21.3",
		"ansi-colors": "4.1.3",
		"minimist": "1.2.8",
		"puppeteer": "24.37.5"
	},
	"devDependencies": {
		"@types/minimist": "1.2.5"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/d-zero-dev/tools.git",
		"directory": "packages/@d-zero/replicator"
	}
