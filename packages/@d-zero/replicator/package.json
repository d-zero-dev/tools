{
	"name": "@d-zero/replicator",
	"version": "0.9.6",
	"description": "Replicate web pages with all their resources to local directories",
	"author": "D-ZERO",
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"type": "module",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
