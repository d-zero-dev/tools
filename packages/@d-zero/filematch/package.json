{
	"name": "@d-zero/filematch",
	"version": "1.1.0",
	"description": "A simple file matching library",
	"author": "D-ZERO",
	"license": "MIT",
	"publishConfig": {
		"access": "public"
	},
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"bin": "./dist/cli.js",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc",
		"watch": "tsc --watch",
		"clean": "tsc --build --clean"
	},
	"dependencies": {
		"@d-zero/readtext": "1.1.13",
		"follow-redirects": "1.15.11",
		"minimist": "1.2.8"
	},
	"devDependencies": {
		"@types/follow-redirects": "1.14.4",
		"@types/node": "24.10.1"
	}
}
